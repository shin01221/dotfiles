layout {

    focus-ring {
        active-color   "#ffb3ad"
        inactive-color "#181211"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#ffb3ad"
        inactive-color "#181211"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#ffb3ad"
        inactive-color "#7e2a28"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#ffb3ad80"
    }
}

recent-windows {
    highlight {
        active-color "#ffb3ad"
        urgent-color "#ffb4ab"
    }
}
