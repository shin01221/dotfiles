layout {

    focus-ring {
        active-color   "#ffb3b2"
        inactive-color "#181212"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#ffb3b2"
        inactive-color "#181212"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#ffb3b2"
        inactive-color "#7e2a2e"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#ffb3b280"
    }
}

recent-windows {
    highlight {
        active-color "#ffb3b2"
        urgent-color "#ffb4ab"
    }
}
